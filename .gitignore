# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environment
.venv/
venv/
env/
claude/
agents/

# Environment variables — NEVER commit these
.env
.env.local
.env.production
.env.example 
# Database
*.db
*.sqlite3

# Alembic — don't commit generated migration files but keep the folder
alembic/versions/*.py
!alembic/versions/.gitkeep

# Audio files — stored in R2, not in git
static/audio/
static/uploads/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# VS Code
.vscode/
*.code-workspace

# PyCharm
.idea/

# Logs
*.log
logs/

# Testing
.pytest_cache/
.coverage
htmlcov/

# Temporary files
tmp/
temp/
*.tmp

# Docker — don't commit local override files
docker-compose.override.yml
